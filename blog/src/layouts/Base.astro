---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Derek Bolyard</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      html {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 18px;
        line-height: 1.6;
        background: #f5f5f4;
        color: #525252;
      }

      body {
        margin: 0;
        padding: 0;
      }

      main {
        max-width: 640px;
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }

      a {
        color: #171717;
        text-underline-offset: 3px;
      }

      a:hover {
        color: #525252;
      }

      nav {
        margin-bottom: 3rem;
        font-size: 0.875rem;
        color: #a3a3a3;
      }

      nav a {
        color: #a3a3a3;
        text-decoration: none;
      }

      nav a:hover {
        color: #171717;
      }

      /* Post content styles */
      .prose h1, .prose h2, .prose h3 {
        color: #171717;
        line-height: 1.3;
        margin-top: 2em;
        margin-bottom: 0.5em;
      }

      .prose h1 { font-size: 1.75rem; margin-top: 0; }
      .prose h2 { font-size: 1.25rem; }
      .prose h3 { font-size: 1rem; }

      .prose p { margin: 1em 0; }

      .prose code {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.85em;
        background: #e7e5e4;
        padding: 0.15em 0.35em;
        border-radius: 3px;
        color: #171717;
      }

      .prose pre {
        background: #1c1917;
        color: #e7e5e4;
        padding: 1.25rem 1.5rem;
        border-radius: 6px;
        overflow-x: auto;
        font-size: 0.85rem;
        line-height: 1.7;
      }

      .prose pre code {
        background: none;
        padding: 0;
        color: inherit;
        font-size: inherit;
      }

      .prose blockquote {
        border-left: 3px solid #d4d4d4;
        margin: 1.5em 0;
        padding: 0 0 0 1.25rem;
        color: #737373;
        font-style: italic;
      }

      .prose hr {
        border: none;
        border-top: 1px solid #e5e5e5;
        margin: 2.5em 0;
      }

      .prose ul, .prose ol {
        padding-left: 1.5rem;
        margin: 1em 0;
      }

      .prose li { margin: 0.25em 0; }

      .prose img {
        max-width: 100%;
        border-radius: 4px;
      }

      ::selection { background: rgba(163, 163, 163, 0.2); }
    </style>
  </head>
  <body>
    <main>
      <nav>
        <a href="/">← Derek Bolyard</a>
      </nav>
      <slot />
    </main>
  </body>
</html>
